# Content Dashboard — Environment Variables
# Kopiere diese Datei zu .env und trag deine eigenen Keys ein.

# ============================================================
# PFLICHT
# ============================================================

# Apify (Instagram + TikTok Tracking)
# https://apify.com -> Settings -> Integrations -> API -> Personal API Token
APIFY_API_TOKEN=

# Anthropic (Claude fuer Markt-Analyse, Topic-Clustering)
# https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# Workspace-Pfad (absoluter Pfad zum Root dieses Repos)
# Beispiel: /Users/dein-name/Developer/content-dashboard-lite
WORKSPACE_PATH=
