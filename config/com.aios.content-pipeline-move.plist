<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aios.content-pipeline-move</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON_PATH__</string>
        <string>__WORKSPACE_PATH__/scripts/content_pipeline_move.py</string>
    </array>

    <!-- Stuendlich auf Minute :40, kurz nach dem self-hot-Tracker (:30).
         So wird ein gepostetes Reel binnen ~70 Min automatisch von pipeline/bereit
         nach library/instagram/ verschoben, statt erst am nächsten Tag 06:35. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <key>WorkingDirectory</key>
    <string>__WORKSPACE_PATH__</string>

    <key>StandardOutPath</key>
    <string>__LOG_PATH__/content-pipeline-move.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_PATH__/content-pipeline-move.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>
</dict>
</plist>
